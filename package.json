{
  "name": "pressure-game-monorepo",
  "version": "1.0.0",
  "description": "Pressure Game - Cross-platform pipe puzzle game (Web + Mobile with Expo)",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/mobile"
  ],
  "scripts": {
    "start": "./scripts/start-dev.sh",
    "dev": "./scripts/start-dev.sh",
    "prod": "./scripts/start-prod.sh",
    "build:prod": "./scripts/start-prod.sh",
    "web:dev": "cd apps/web && npm run dev",
    "web:build": "cd apps/web && npm run build",
    "web:preview": "cd apps/web && npm run preview",
    "web:lint": "cd apps/web && npm run lint",
    "web:test": "cd apps/web && npm test",
    "mobile:start": "cd apps/mobile && expo start",
    "mobile:build": "cd apps/mobile && eas build",
    "mobile:preview:ios": "./scripts/ios-preview.sh",
    "mobile:preview:android": "./scripts/android-preview.sh",
    "mobile:test": "cd apps/mobile && npm test",
    "build": "npm run web:build && npm run mobile:build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:web": "cd apps/web && npm test",
    "test:all": "npm run test && npm run test:web && npm run mobile:test",
    "lint": "npm run web:lint",
    "sonar:start": "docker run -d --name sonarqube -e SONAR_ES_BOOTSTRAP_CHECKS_DISABLED=true -p 9000:9000 sonarqube:latest && echo 'SonarQube starting at http://localhost:9000 (login: admin/admin)'",
    "sonar:stop": "docker stop sonarqube && docker rm sonarqube",
    "sonar:analyze": "node --max-old-space-size=4096 node_modules/sonarqube-scanner/bin/sonar-scanner.js -Dsonar.projectKey=pressure-game -Dsonar.sources=src,apps/web/src,apps/mobile -Dsonar.host.url=http://localhost:9000 -Dsonar.token=squ_016dd3f0d8840fa5b5baef431bbcb44b323362a9 -Dsonar.exclusions=**/node_modules/**,**/*.test.ts,**/*.test.tsx,**/dist/**,**/.next/**,**/build/**,**/.expo/**,**/coverage/**,**/cli/**",
    "sonar:clean": "npm run sonar:stop && npm run sonar:start"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "jsdom": "^28.1.0",
    "sonarqube-scanner": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "5.4.11",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/plugin-transform-react-jsx": "7.25.9",
      "@babel/preset-react": "7.25.9"
    }
  }
}
