{
  "name": "pressure-game-monorepo",
  "version": "1.0.0",
  "description": "Pressure Game - Cross-platform pipe puzzle game (Web + Mobile with Expo)",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/mobile"
  ],
  "scripts": {
    "start": "./scripts/start-dev.sh",
    "dev": "./scripts/start-dev.sh",
    "prod": "./scripts/start-prod.sh",
    "build:prod": "./scripts/start-prod.sh",
    "web:dev": "cd apps/web && npm run dev",
    "web:build": "cd apps/web && npm run build",
    "web:preview": "cd apps/web && npm run preview",
    "web:lint": "cd apps/web && npm run lint",
    "web:test": "cd apps/web && npm test",
    "mobile:start": "cd apps/mobile && expo start",
    "mobile:build": "cd apps/mobile && eas build",
    "mobile:preview:ios": "./scripts/ios-preview.sh",
    "mobile:preview:android": "./scripts/android-preview.sh",
    "mobile:test": "cd apps/mobile && npm test",
    "build": "npm run web:build && npm run mobile:build",
    "test": "npm run web:test",
    "test:all": "npm run web:test && npm run mobile:test",
    "lint": "npm run web:lint"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zustand": "^4.5.5"
  }
}
