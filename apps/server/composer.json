{
  "name": "pressure/server",
  "description": "Pressure Game PHP backend",
  "type": "library",
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpunit/php-code-coverage": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Pressure\\": "src/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-xml=coverage.xml --log-junit=test-report.xml"
  }
}
