{
  "name": "pressure-game",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test:game": "npx tsx src/cli/game-tester.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:pressure": "playwright test tests/e2e/pressure-basic.spec.ts",
    "test:solver": "playwright test tests/e2e/pipe-solver.spec.ts --project=solver",
    "test:solver:classic": "TEST_MODE=classic playwright test tests/e2e/pipe-solver.spec.ts --project=solver",
    "test:solver:zen": "TEST_MODE=zen playwright test tests/e2e/pipe-solver.spec.ts --project=solver",
    "test:solver:blitz": "TEST_MODE=blitz playwright test tests/e2e/pipe-solver.spec.ts --project=solver",
    "solve": "npx tsx src/cli/level-solver.ts",
    "solve:json": "npx tsx src/cli/level-solver.ts --json",
    "generate:pressure": "npx tsx src/cli/pressure-level-generator.ts",
    "enhance": "npx tsx src/cli/level-enhancer.ts",
    "sonar:start": "docker run -d --name sonarqube -e SONAR_ES_BOOTSTRAP_CHECKS_DISABLED=true -p 9000:9000 sonarqube:latest && echo 'SonarQube starting at http://localhost:9000 (login: admin/admin)'",
    "sonar:stop": "docker stop sonarqube && docker rm sonarqube",
    "sonar:analyze": "node --max-old-space-size=4096 node_modules/sonarqube-scanner/bin/sonar-scanner.js -Dsonar.projectKey=pressure-game -Dsonar.sources=src,../server/src -Dsonar.host.url=http://localhost:9000 -Dsonar.token=$SONAR_TOKEN",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "eslint": "^9",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "sonarqube-scanner": "^4.3.4",
    "typescript": "^5",
    "vite": "5.4.11",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.0"
  }
}
