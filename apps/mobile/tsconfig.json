{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/components/*": ["../web/components/*"],
      "@/hooks/*": ["../web/src/hooks/*"],
      "@/*": ["../../src/*"],
      "@/game/*": ["../../src/game/*"],
      "@/utils/*": ["../../src/utils/*"],
      "@/config/*": ["../../src/config/*"],
      "@/shared/*": ["../../src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
