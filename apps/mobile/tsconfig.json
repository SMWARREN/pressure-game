{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@/game/*": ["../../src/game/*"],
      "@/utils/*": ["../../src/utils/*"],
      "@/config/*": ["../../src/config/*"],
      "@/shared/*": ["../../src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
